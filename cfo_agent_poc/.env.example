# Web access
CFO_WEB_HOST=127.0.0.1
CFO_WEB_PORT=8091
CFO_ACCESS_TOKEN=change-me
# 账本主人的名字：会显示在登录页并注入 CFO Agent 的系统提示词
CFO_OWNER_NAME=Jeanz

# QQ Mail IMAP capture pipeline
CFO_MAIL_IMAP_HOST=imap.qq.com
CFO_MAIL_USER=your-email@qq.com
CFO_MAIL_PASSWORD=your-imap-authorization-code
CFO_MAIL_MAILBOX=INBOX
CFO_MAIL_SUBJECT=CFO_CAPTURE_SCREENSHOT

# DeepSeek chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_THINKING=disabled

# Runtime tuning
CFO_CHAT_TIMEOUT_SECONDS=45
CFO_MAIL_SYNC_TIMEOUT_SECONDS=90
CFO_MAIL_SYNC_MAX_CANDIDATES=20
